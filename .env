# Environment Configuration
NODE_ENV=development
PORT=5000

# Database
# For local MongoDB: mongodb://localhost:27017/ai-placement-mentor
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/ai-placement-mentor
MONGODB_URI=mongodb://localhost:27017/ai-placement-mentor

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Frontend URL
FRONTEND_URL=http://localhost:8000

# Email (optional - for future features)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password